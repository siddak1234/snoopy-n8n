# ----------------------------
# n8n base config (LOCAL DEV)
# ----------------------------
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678

# ----------------------------
# Security (COPY to .env and change there)
# ----------------------------
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_LONG_RANDOM
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# ----------------------------
# Timezone
# ----------------------------
GENERIC_TIMEZONE=America/Chicago
TZ=America/Chicago